{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foundry/agents/schema.json",
  "title": "Foundry agent manifest (charter/AGENTS.md, MASTER.md P0.1, ADR-026)",
  "type": "object",
  "required": ["id", "role", "trigger", "trust_tier", "quota_tier", "capability", "outputs", "heartbeat"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "role": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "trigger": { "enum": ["schedule", "dispatch", "event"] },
    "trust_tier": { "enum": ["trusted", "ingests_untrusted"] },
    "quota_tier": { "enum": ["product", "high", "low"] },
    "capability": {
      "type": "string",
      "pattern": "^(read_only|proposes|writes:.+)$"
    },
    "outputs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "heartbeat": {
      "type": "object",
      "required": ["interval_hours"],
      "additionalProperties": false,
      "properties": { "interval_hours": { "type": "number", "exclusiveMinimum": 0 } }
    },
    "prompt": { "type": "string" },
    "workflow": { "type": "string" },
    "gates": { "type": "array", "items": { "type": "string" } },
    "lands_via": { "enum": ["orchestrator"] },
    "fenced": { "type": "boolean" },
    "status": { "enum": ["active", "dormant"] }
  }
}
